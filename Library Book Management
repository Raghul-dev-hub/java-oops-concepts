Problem Statement

Create a Java application to maintain the details of multiple books using an array of objects. Each book should contain the title, author name, and price.
Store the details of five books and display all the book information in a formatted manner.

class Book {

    String title;
    String author;
    double price;

    Book(String t, String a, double p) {
        title = t;
        author = a;
        price = p;
    }

    void display() {
        System.out.println("Book Title  : " + title);
        System.out.println("Author      : " + author);
        System.out.println("Price       : Rs." + price);
        System.out.println();
    }
}

public class LibraryManagement {

    public static void main(String[] args) {

        Book[] books = new Book[5];

        books[0] = new Book("Java Programming", "James", 550);
        books[1] = new Book("Data Structures", "Mark", 480);
        books[2] = new Book("Operating System", "William", 620);
        books[3] = new Book("Computer Networks", "Andrew", 700);
        books[4] = new Book("DBMS", "Thomas", 530);

        for (int i = 0; i < books.length; i++) {
            books[i].display();
        }
    }
}
